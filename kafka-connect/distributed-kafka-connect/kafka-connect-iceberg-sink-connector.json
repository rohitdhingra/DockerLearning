{
  "name": "iceberg-sink-connector",
  "config": {
    "connector.class": "org.apache.iceberg.connect.IcebergSinkConnector",
    "tasks.max": "1",
    "topics": "test_topic",
    "iceberg.tables": "test_table",
    "iceberg.catalog.catalog-impl": "org.apache.iceberg.nessie.NessieCatalog",
    "iceberg.catalog.uri": "http://nessie:19120/api/v1",
    "iceberg.catalog.client-api-version": "1",
    "iceberg.catalog.warehouse": "s3://my-bucket/warehouse",
    "iceberg.catalog.io-impl": "org.apache.iceberg.aws.s3.S3FileIO",
    "iceberg.catalog.s3.endpoint": "http://minio:9000",
    "iceberg.catalog.s3.access-key-id": "minio",
    "iceberg.catalog.s3.secret-access-key": "minio123",
    "iceberg.catalog.s3.path-style-access": "true",
    "iceberg.control.topic": "iceberg-control-events",
    "iceberg.control.group.id": "iceberg-control-group",
    "iceberg.table.auto-create": "true",
    "iceberg.table.dynamic-schema-evolution": "true",
    "iceberg.table.write.format.default": "parquet",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}